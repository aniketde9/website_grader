    "csv-parse": "^5.5.5",
    "csv-stringify": "^6.4.6",
    "p-limit": "^4.0.0",
    "dotenv": "^16.4.5",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "color": "^4.2.3",
    "cheerio": "^1.0.0-rc.12",
    "winston": "^3.13.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nock": "^13.5.4"
  }
