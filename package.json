{
  "name": "website-grader",
  "version": "1.0.0",
  "description": "CRO parameter grader for competitor websites scraped from ads",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
