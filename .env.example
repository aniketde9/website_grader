# Claude API (for Tier 3 LLM checks)
ANTHROPIC_API_KEY=sk-ant-...

# Google PageSpeed Insights API
PAGESPEED_API_KEY=AIza...

CONCURRENCY=3
REQUEST_DELAY_MS=1500
PAGE_TIMEOUT_MS=30000
# Sonnet 4.6 (caveman: 8 comma-separated ints only; override if needed)
CLAUDE_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=50
OUTPUT_PATH=./results.csv
LOG_LEVEL=info
SKIP_ERROR_SITES=true
LLM_VISION_HERO=false
